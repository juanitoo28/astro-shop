# ============================================================
#  VARIABLES D'ENVIRONNEMENT — Copier en .env pour le local
#  À configurer dans Netlify > Site > Environment variables
# ============================================================

# Mot de passe de l'interface admin
ADMIN_PASSWORD=admin1234

# GitHub Personal Access Token (classic)
# Permissions requises : repo (read + write)
# Créer sur : https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx

# Votre repo GitHub (format: username/repo-name)
GITHUB_REPO=votre-username/astro-shop

# Branche principale du repo
GITHUB_BRANCH=main

# Chemin du fichier data.json dans le repo
GITHUB_DATA_PATH=admin/data.json
