---
import { siteConfig } from '../data/config';
const { about } = siteConfig;
---

<section class="about-section" id="about">
  <div class="container">
    <div class="about-section__inner">
      <div class="about-section__text">
        <h2 class="about-section__title">{about.title}</h2>
        <p class="about-section__desc">{about.text}</p>
        <div class="about-section__values">
          {about.values.map(val => (
            <div class="about-value">
              <span class="about-value__icon">{val.icon}</span>
              <span class="about-value__label">{val.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="about-section__images">
        <div class="about-img about-img--top">
          <img
            src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80"
            alt="Atelier"
            loading="lazy"
          />
        </div>
        <div class="about-img about-img--bottom">
          <img
            src="https://images.unsplash.com/photo-1556905055-8f358a7a47b2?w=600&q=80"
            alt="Tissus naturels"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.about-section {
  padding: 6rem 0;
  background: var(--bg-alt);
}

.about-section__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: center;
}

.about-section__title {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 300;
  letter-spacing: -0.01em;
  margin-bottom: 1.5rem;
}

.about-section__desc {
  font-size: 1rem;
  color: var(--text-muted);
  line-height: 1.8;
  max-width: 480px;
  margin-bottom: 2.5rem;
}

.about-section__values {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.about-value {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.85rem 1.25rem;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}

.about-value__icon {
  font-size: 1rem;
  color: var(--text-muted);
}

.about-value__label {
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.04em;
}

/* Images layout */
.about-section__images {
  position: relative;
  height: 480px;
}

.about-img {
  position: absolute;
  overflow: hidden;
  border-radius: 4px;
}

.about-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.about-img:hover img { transform: scale(1.03); }

.about-img--top {
  top: 0; right: 0;
  width: 70%; height: 60%;
}

.about-img--bottom {
  bottom: 0; left: 0;
  width: 55%; height: 50%;
}

/* Responsive */
@media (max-width: 768px) {
  .about-section__inner {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .about-section__images { height: 280px; }
}
</style>
